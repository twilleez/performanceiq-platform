================================================================
FILE: .env.example
================================================================

# ============================================================
# PIQ Recovery — Environment Variables
# Copy to .env.local (frontend) and .env (backend)
# ============================================================

# ── SUPABASE ─────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://jijqjbgmhhlvokgtuema.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── PUSH NOTIFICATIONS (Web Push VAPID) ──────────────────────
VAPID_EMAIL=notifications@performanceiq.app
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key

# ── NUTRITION API ─────────────────────────────────────────────
USDA_API_KEY=your_usda_api_key
# Free key from: https://api.nal.usda.gov/

# ── ANALYTICS (PostHog) ───────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=your_posthog_project_key
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
NEXT_PUBLIC_ANALYTICS_ENABLED=true

# ── APP ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://twilleez.github.io/performanceiq-platform
NODE_ENV=production

# ── STORAGE BUCKET ───────────────────────────────────────────
# Create bucket named "piq-reports" in Supabase Storage
# Set policy: authenticated users can read their own reports
